# ============================================
# DATABASE CONFIGURATION
# ============================================
# Run: npm run db:use -- mssql|postgresql|mysql
# Then set the matching DATABASE_URL below

# PostgreSQL
DATABASE_URL="postgresql://itms_user:your_password@localhost:5432/itms?schema=public"

# MSSQL (uncomment and comment above)
# DATABASE_URL="sqlserver://localhost:1433;database=ITMS;user=sa;password=YourPass;encrypt=false;trustServerCertificate=true"

# MySQL (uncomment and comment above)
# DATABASE_URL="mysql://itms_user:your_password@localhost:3306/itms"

# ============================================
# NEXTAUTH
# ============================================
NEXTAUTH_SECRET=change-this-to-a-very-secure-random-string-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ============================================
# APP CONFIG
# ============================================
NODE_ENV=development
